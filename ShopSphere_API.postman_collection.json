{
  "info": {
    "name": "ShopSphere API",
    "description": "Complete API collection for the ShopSphere Android app backend.\n\n**Setup:**\n1. Import this file into Postman (drag & drop into the sidebar).\n2. Set the `base_url` collection variable if the ngrok URL changes.\n3. Run **Auth → Login** first — the test script auto-saves `token` for all other requests.\n\nAll endpoints except Auth/Products use Bearer token auth.",
    "_postman_id": "shopsphere-api-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://shila-unanatomised-mouthily.ngrok-free.dev/api/Graduation_Project",
      "type": "string"
    },
    { "key": "token", "value": "", "type": "string" },
    { "key": "product_id", "value": "3", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token saved:', json.token.substring(0, 20) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ooooghhshahh@o.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/Login",
              "host": ["{{base_url}}"],
              "path": ["Login"]
            }
          }
        },
        {
          "name": "SignUp",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token saved:', json.token.substring(0, 20) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"FullName\": \"Test User\",\n  \"Email\": \"test@example.com\",\n  \"Password\": \"123456\",\n  \"Phone\": \"0123456789\",\n  \"Address\": \"Cairo, Egypt\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/SignUp",
              "host": ["{{base_url}}"],
              "path": ["SignUp"]
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/All_Products",
              "host": ["{{base_url}}"],
              "path": ["All_Products"]
            }
          }
        },
        {
          "name": "Beauty Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/Beauty_Products",
              "host": ["{{base_url}}"],
              "path": ["Beauty_Products"]
            }
          }
        },
        {
          "name": "Fragrances Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/Fragrances_Products",
              "host": ["{{base_url}}"],
              "path": ["Fragrances_Products"]
            }
          }
        },
        {
          "name": "Furniture Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/Furniture_Products",
              "host": ["{{base_url}}"],
              "path": ["Furniture_Products"]
            }
          }
        },
        {
          "name": "Groceries Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/Groeries_Products",
              "host": ["{{base_url}}"],
              "path": ["Groeries_Products"]
            }
          }
        },
        {
          "name": "Home Decoration Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/HomeDecoration_Products",
              "host": ["{{base_url}}"],
              "path": ["HomeDecoration_Products"]
            }
          }
        },
        {
          "name": "Jewelery Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/Jewelery_Products",
              "host": ["{{base_url}}"],
              "path": ["Jewelery_Products"]
            }
          }
        },
        {
          "name": "Men's Clothing Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/MenIsClothing_Products",
              "host": ["{{base_url}}"],
              "path": ["MenIsClothing_Products"]
            }
          }
        },
        {
          "name": "Women's Clothing Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/SwomenIsClothing_Products",
              "host": ["{{base_url}}"],
              "path": ["SwomenIsClothing_Products"]
            }
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart Items",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/GetCartItems",
              "host": ["{{base_url}}"],
              "path": ["GetCartItems"]
            }
          }
        },
        {
          "name": "Add To Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "ngrok-skip-browser-warning", "value": "true" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productID\": 6,\n  \"quantity\": 3\n}"
            },
            "url": {
              "raw": "{{base_url}}/AddToCart",
              "host": ["{{base_url}}"],
              "path": ["AddToCart"]
            }
          }
        },
        {
          "name": "Update Quantity",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "ngrok-skip-browser-warning", "value": "true" }
            ],
            "url": {
              "raw": "{{base_url}}/UpdateQuantity?productId=1&newQuantity=2",
              "host": ["{{base_url}}"],
              "path": ["UpdateQuantity"],
              "query": [
                { "key": "productId", "value": "1" },
                { "key": "newQuantity", "value": "2" }
              ]
            }
          }
        },
        {
          "name": "Remove From Cart",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "ngrok-skip-browser-warning", "value": "true" }
            ],
            "url": {
              "raw": "{{base_url}}/RemoveFromCart?productId=1",
              "host": ["{{base_url}}"],
              "path": ["RemoveFromCart"],
              "query": [
                { "key": "productId", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/ClearCart",
              "host": ["{{base_url}}"],
              "path": ["ClearCart"]
            }
          }
        }
      ]
    },
    {
      "name": "Favorites",
      "description": "Favorites endpoints. Use `{{product_id}}` variable to switch which product you're testing.",
      "item": [
        {
          "name": "Get All Favorites",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Body parses as JSON', function () {",
                  "    pm.response.json();",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "ngrok-skip-browser-warning", "value": "true" }
            ],
            "url": {
              "raw": "{{base_url}}/GetAllFavorites",
              "host": ["{{base_url}}"],
              "path": ["GetAllFavorites"]
            }
          }
        },
        {
          "name": "Add To Favorite",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200/201/204', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 204]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "ngrok-skip-browser-warning", "value": "true" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{product_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/AddToFavorite",
              "host": ["{{base_url}}"],
              "path": ["AddToFavorite"]
            }
          }
        },
        {
          "name": "Remove From Favorite",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 204', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "ngrok-skip-browser-warning", "value": "true" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{product_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/RemoveFromFavorite",
              "host": ["{{base_url}}"],
              "path": ["RemoveFromFavorite"]
            }
          }
        }
      ]
    }
  ]
}
