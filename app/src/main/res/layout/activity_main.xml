<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CleanArchitecture.ui.views.MainActivity"
    android:background="#FFFFFF">

    <!-- Content fills the whole screen. The floating nav draws on top, so
         fragments that have scrollable content add bottom padding of
         72dp (nav height) + 16dp margin + safe area to avoid being clipped. -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph" />

    <!-- Floating pill-shaped bottom navigation: 16dp side margins, rounded
         corners, elevated shadow. -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_bottom_nav_floating"
        android:elevation="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_navigation"
        app:itemIconTint="@color/bottom_nav_selector"
        app:itemTextColor="@color/bottom_nav_selector"
        app:itemRippleColor="@color/bottom_nav_ripple"
        app:itemIconSize="22dp"
        app:itemPaddingTop="6dp"
        app:itemPaddingBottom="6dp"
        app:itemTextAppearanceActive="@style/TextAppearance.App.BottomNavLabel.Active"
        app:itemTextAppearanceInactive="@style/TextAppearance.App.BottomNavLabel"
        app:itemActiveIndicatorStyle="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
