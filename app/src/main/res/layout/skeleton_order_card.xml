<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:shimmer_auto_start="true"
    app:shimmer_base_color="@color/shimmer_color"
    app:shimmer_highlight_color="@color/shimmer_highlight"
    app:shimmer_duration="1200">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="18dp"
        app:cardElevation="2dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp">

            <View
                android:id="@+id/skelThumb"
                android:layout_width="78dp"
                android:layout_height="88dp"
                android:background="@color/shimmer_color"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/skelTitle"
                android:layout_width="0dp"
                android:layout_height="16dp"
                android:layout_marginStart="14dp"
                android:background="@color/shimmer_color"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/skelThumb"
                app:layout_constraintTop_toTopOf="@id/skelThumb" />

            <View
                android:id="@+id/skelSubtitle"
                android:layout_width="120dp"
                android:layout_height="12dp"
                android:layout_marginStart="14dp"
                android:layout_marginTop="10dp"
                android:background="@color/shimmer_color"
                app:layout_constraintStart_toEndOf="@id/skelThumb"
                app:layout_constraintTop_toBottomOf="@id/skelTitle" />

            <View
                android:id="@+id/skelTotal"
                android:layout_width="90dp"
                android:layout_height="18dp"
                android:layout_marginStart="14dp"
                android:background="@color/shimmer_color"
                app:layout_constraintBottom_toBottomOf="@id/skelThumb"
                app:layout_constraintStart_toEndOf="@id/skelThumb" />

            <View
                android:id="@+id/skelBtn"
                android:layout_width="100dp"
                android:layout_height="38dp"
                android:background="@color/shimmer_color"
                app:layout_constraintBottom_toBottomOf="@id/skelThumb"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</com.facebook.shimmer.ShimmerFrameLayout>
