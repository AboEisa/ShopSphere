<?xml version="1.0" encoding="utf-8"?>
<!-- Modern loading overlay with gradient background and animated progress -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/loading_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_loading_overlay"
    android:visibility="gone"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Modern circular progress with gradient -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progress_indicator"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminate="true"
            app:indicatorColor="@color/bright_green"
            app:trackColor="#1A23a36e"
            app:trackThickness="4dp" />

        <!-- Loading text -->
        <TextView
            android:id="@+id/loading_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Loading..."
            android:textColor="#1A1A1A"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/loading_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Please wait"
            android:textColor="#808080"
            android:textSize="14sp" />

        <!-- Cancel button shown when payment is in progress -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_loading"
            android:layout_width="140dp"
            android:layout_height="44dp"
            android:layout_marginTop="36dp"
            android:text="Cancel"
            android:textColor="@color/bright_green"
            android:textSize="14sp"
            android:visibility="gone"
            app:backgroundTint="#1A23a36e"
            app:cornerRadius="22dp"
            app:strokeColor="@color/bright_green"
            app:strokeWidth="1dp" />

    </LinearLayout>

</FrameLayout>