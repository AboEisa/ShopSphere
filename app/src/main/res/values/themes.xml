<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ShopSphere" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
    </style>

    <style name="Theme.ShopSphere" parent="Base.Theme.ShopSphere" />

    <style name="Widget.App.SeekBar" parent="Widget.MaterialComponents.Slider">
        <item name="trackColorInactive">@color/seekbar_inactive</item>
        <item name="trackColorActive">@color/seekbar_active</item>
        <item name="thumbColor">@color/seekbar_thumb</item>
        <item name="haloColor">@color/seekbar_halo</item>
    </style>

    <!-- Compact text style for the floating bottom navigation labels so they
         don't get clipped in the 5-tab pill layout. -->
    <style name="TextAppearance.App.BottomNavLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.App.BottomNavLabel.Active">
        <item name="android:textStyle">bold</item>
    </style>

</resources>